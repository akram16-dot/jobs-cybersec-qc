# Supabase (à récupérer dans Supabase > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx...

# Adzuna (https://developer.adzuna.com/ — gratuit, 250 appels/mois)
ADZUNA_APP_ID=xxxxxxxx
ADZUNA_APP_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Jooble (https://jooble.org/api/about — gratuit, sans limite stricte)
JOOBLE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Token secret pour protéger /api/ingest (invente une longue chaîne aléatoire)
INGEST_SECRET=remplace-moi-par-une-chaine-aleatoire-tres-longue
